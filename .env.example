# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase.
# Encontre em: https://supabase.com → seu projeto → Settings → API

# Públicas (vão pro cliente — começam com VITE_)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Privada (apenas para serverless functions — NUNCA EXPOR NO CLIENTE)
# Encontre em: Supabase → Settings → API → service_role secret
# Vai ser configurada apenas no painel da Vercel (Project Settings → Environment Variables)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------- WhatsApp Cloud API (Meta) ----------
# Configurar APENAS no painel da Vercel
# WHATSAPP_VERIFY_TOKEN: string aleatória que VOCÊ inventa (não vem do Meta).
#   Tem que ser idêntica à que você coloca no Meta na hora de configurar o webhook.
# WHATSAPP_PHONE_NUMBER_ID: vem da Meta → WhatsApp → API Setup → Phone Number ID
# WHATSAPP_ACCESS_TOKEN: vem da Meta → WhatsApp → API Setup → Token de acesso
WHATSAPP_VERIFY_TOKEN=alguma-string-aleatoria-que-voce-inventa
WHATSAPP_PHONE_NUMBER_ID=1119483577914737
WHATSAPP_ACCESS_TOKEN=EAA...

# ---------- Anthropic (Claude) ----------
# https://console.anthropic.com → API Keys
# Usado pelo webhook do WhatsApp pra extrair gastos das mensagens
ANTHROPIC_API_KEY=sk-ant-...

# ---------- OpenAI (Whisper) ----------
# https://platform.openai.com/api-keys
# Usado pelo webhook pra transcrever áudios recebidos no WhatsApp
OPENAI_API_KEY=sk-...
